    "scripts": {
        "clear": "rm -rf dist/",
        "clear:all": "rm -rf node_modules/ && npm run clear",
        "lint": "eslint .",
        "deploy": "NODE_DEBUG=gh-pages gh-pages -d dist/",
        "prebuild": "npm run clear",
        "build": "npm run build:development",
        "build:development": "webpack --config webpack/webpack.config.js --env addons=replaceString",
        "build:production": "webpack --config webpack/webpack.config.js --env.production --env addons=replaceString",
        "start": "http-server dist/ -c-1",
        "dev": "webpack serve --config webpack/webpack.config.js --env addons=replaceString"
    },
    "devDependencies": {
        "@babel/core": "^7.23.2",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-transform-runtime": "^7.23.2",
        "@babel/preset-env": "^7.23.2",
        "@babel/runtime": "^7.23.2",
        "babel-eslint": "^10.1.0",
        "babel-loader": "^8.1.0",
        "copy-webpack-plugin": "^6.2.1",
        "cross-env": "^7.0.3",
        "css-loader": "^5.0.0",
        "debug": "^4.3.4",
        "eslint": "^5.16.0",
        "eslint-config-piecioshka": "^2.2.4",
        "file-loader": "^6.2.0",
        "gh-pages": "^3.1.0",
        "http-server": "^0.12.3",
        "husky": "^4.3.0",
        "lint-staged": "^10.4.2",
        "prettier": "^2.1.2",
        "string-replace-loader": "^3.1.0",
        "style-loader": "^2.0.0",
        "webpack": "^5.89.0",
        "webpack-bundle-analyzer": "^3.9.0",
        "webpack-cli": "^4.1.0",
        "webpack-dev-server": "^3.11.0",
        "webpack-merge": "^5.10.0"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:piecioshka/game.git"
    }
}
